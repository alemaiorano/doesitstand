{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "reference_check_report.v1",
  "type": "object",
  "required": ["paper_path", "generated_at", "references"],
  "properties": {
    "paper_path": {"type": "string"},
    "generated_at": {"type": "string"},
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["raw_ref", "resolved"],
        "properties": {
          "raw_ref": {"type": "string"},
          "arxiv_id": {"type": ["string", "null"]},
          "doi": {"type": ["string", "null"]},
          "resolved": {"type": "boolean"},
          "metadata": {"type": ["object", "null"]}
        }
      }
    },
    "resolution_rate": {"type": "number"}
  }
}
